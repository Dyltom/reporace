{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Dyltom/reporace/main/schema/task.schema.json",
  "title": "RepoRace task",
  "type": "object",
  "required": ["id", "title", "prompt", "checks"],
  "properties": {
    "id": { "type": "string", "minLength": 1, "pattern": "^[a-zA-Z0-9._-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "prompt": { "type": "string", "minLength": 1 },
    "setup": { "type": "array", "items": { "$ref": "#/$defs/step" } },
    "checks": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/step" } },
    "repetitions": { "type": "integer", "minimum": 1 }
  },
  "additionalProperties": false,
  "$defs": {
    "command": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "array", "minItems": 1, "items": { "type": "string" } }
      ]
    },
    "step": {
      "type": "object",
      "required": ["name", "command"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "command": { "$ref": "#/$defs/command" },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "env": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
